# --- Primary LLM: Ollama (local, free) ---
# Install: https://ollama.com  then: ollama pull llama3.1
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434

# --- Fallback LLM: Azure OpenAI ---
# Used automatically when Ollama is unreachable.
# Leave blank to disable the fallback (Ollama errors will surface instead).
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-02-01

# --- MLflow tracking ---
MLFLOW_TRACKING_URI=http://localhost:5000

# --- Azure ML training (optional, leave blank for stubbed mode) ---
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_ML_WORKSPACE=
AZURE_COMPUTE=cpu-cluster
